generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String
  role         String   @default("ADMIN")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Ingredient {
  id           String                    @id @default(cuid())
  name         String
  category     String?
  unitMeasure  String
  currentStock Float                     @default(0)
  minStock     Float                     @default(0)
  unitCost     Float                     @default(0)
  supplier     String?
  notes        String?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  movements    IngredientStockMovement[]
  recipeItems  RecipeItem[]
}

model IngredientStockMovement {
  id                    String     @id @default(cuid())
  ingredientId          String
  type                  String
  quantity              Float
  unitCostAtTransaction Float?
  date                  DateTime   @default(now())
  notes                 String?
  createdAt             DateTime   @default(now())
  ingredient            Ingredient @relation(fields: [ingredientId], references: [id])

  @@index([ingredientId])
  @@index([date])
}

model Flavor {
  id                 String                 @id @default(cuid())
  name               String                 @unique
  description        String?
  suggestedSellPrice Float                  @default(0)
  active             Boolean                @default(true)
  notes              String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  stock              FinishedProductStock?
  productMovements   ProductStockMovement[]
  productionBatches  ProductionBatch[]
  recipes            Recipe[]
  saleItems          SaleItem[]
}

model Recipe {
  id                 String            @id @default(cuid())
  flavorId           String
  yieldUnits         Int
  estimatedTotalCost Float             @default(0)
  estimatedUnitCost  Float             @default(0)
  active             Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  productionBatches  ProductionBatch[]
  flavor             Flavor            @relation(fields: [flavorId], references: [id], onDelete: Cascade)
  items              RecipeItem[]
}

model RecipeItem {
  id           String     @id @default(cuid())
  recipeId     String
  ingredientId String
  quantity     Float
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}

model ProductionBatch {
  id                  String   @id @default(cuid())
  flavorId            String
  recipeId            String
  quantityProduced    Int
  totalProductionCost Float
  date                DateTime @default(now())
  notes               String?
  createdAt           DateTime @default(now())
  flavor              Flavor   @relation(fields: [flavorId], references: [id])
  recipe              Recipe   @relation(fields: [recipeId], references: [id])

  @@index([date])
  @@index([flavorId])
}

model FinishedProductStock {
  id        String   @id @default(cuid())
  flavorId  String   @unique
  quantity  Int      @default(0)
  updatedAt DateTime @updatedAt
  flavor    Flavor   @relation(fields: [flavorId], references: [id], onDelete: Cascade)
}

model ProductStockMovement {
  id        String   @id @default(cuid())
  flavorId  String
  type      String
  quantity  Int
  date      DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())
  flavor    Flavor   @relation(fields: [flavorId], references: [id])

  @@index([flavorId])
  @@index([date])
}

model Sale {
  id             String     @id @default(cuid())
  saleDate       DateTime   @default(now())
  totalAmount    Float
  discountAmount Float      @default(0)
  paymentMethod  String?
  notes          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  items          SaleItem[]

  @@index([saleDate])
}

model SaleItem {
  id                 String @id @default(cuid())
  saleId             String
  flavorId           String
  quantity           Int
  unitSellPrice      Float
  unitCostAtSaleTime Float
  totalMarginLiquid  Float
  flavor             Flavor @relation(fields: [flavorId], references: [id])
  sale               Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

model ExpenseCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expenses  Expense[]
}

model Expense {
  id                String          @id @default(cuid())
  expenseCategoryId String
  description       String
  amount            Float
  expenseDate       DateTime        @default(now())
  isRecurring       Boolean         @default(false)
  invoiceRef        String?         // Número da NF ou referência externa
  notes             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  category          ExpenseCategory @relation(fields: [expenseCategoryId], references: [id])

  @@index([expenseDate])
  @@index([expenseCategoryId])
}
